# ------------------------------------------------------------------------------
# Django Backend Settings
# ------------------------------------------------------------------------------

# SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY=your-super-secret-key-change-me

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=1

# Allowed hosts (comma separated)
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://smartinv_user:smartinv_pass@localhost:5432/smartinv
# Note: When using docker-compose, change HOST to 'db'

# ------------------------------------------------------------------------------
# Email Configuration (SMTP)
# ------------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# ------------------------------------------------------------------------------
# Cloudinary Configuration (Optional for media uploads)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ------------------------------------------------------------------------------
# JWT Configuration
# ------------------------------------------------------------------------------
JWT_ACCESS_EXPIRATION_DAYS=1
JWT_REFRESH_EXPIRATION_DAYS=7
